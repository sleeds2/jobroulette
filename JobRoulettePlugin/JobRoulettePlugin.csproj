<Project Sdk="Dalamud.NET.Sdk/15.0.0">
  <PropertyGroup>
    <TargetFramework>net10.0-windows</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>JobRoulettePlugin</AssemblyName>
    <RootNamespace>JobRoulettePlugin</RootNamespace>

    <!-- SDK/manifest metadata managed directly in csproj (recommended by Dalamud.NET.Sdk migration guidance). -->
    <Author>JobRoulette contributors</Author>
    <Name>Job Roulette</Name>
    <InternalName>JobRoulettePlugin</InternalName>
    <Description>Randomly picks one enabled job and swaps to its gear set via /jobroulette.</Description>
    <DalamudApiLevel>15</DalamudApiLevel>
  </PropertyGroup>
</Project>
